{
  "name": "anicartai-server",
  "version": "1.0.0",
  "description": "AniCartAi - Express.js backend for anime-themed e-commerce wallpaper store",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:worker": "nodemon worker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\"",
    "worker": "node --max-old-space-size=4096 worker.js",
    "seed": "node seed/seedProducts.js"
  },
  "keywords": [
    "anime",
    "e-commerce",
    "wallpaper",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@sentry/node": "^7.120.4",
    "@sentry/tracing": "^7.120.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.71.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-timeout-handler": "^2.2.2",
    "express-validator": "^7.3.1",
    "file-type": "^22.0.0",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "meilisearch": "^0.56.0",
    "mime-types": "^3.0.2",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "p-limit": "^7.3.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^21.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs"
}
