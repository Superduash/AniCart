{
  "name": "anicart-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start:client": "npm start --workspace=client",
    "start:server": "npm run dev --workspace=server",
    "start:worker": "npm run dev:worker --workspace=server",
    "dev": "concurrently \"npm run start:client\" \"npm run start:server\" \"npm run start:worker\"",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
