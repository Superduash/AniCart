# ==============================================================================
# AniCart Express Backend Environment Configuration (Development)
# ==============================================================================

# -----------------------------
# Required System Configurations
# -----------------------------
# Running environment mode (development/production)
NODE_ENV=development

# Port where Express server will listen
PORT=5000

# MongoDB Connection String (Atlas URI or local MongoDB)
MONGODB_URI=mongodb://localhost:27017/AniCartAi

# Secret key used for signing/verifying JWTs
JWT_SECRET=replace_with_a_long_secure_secret_key_32_characters

# Optionally specify separate secrets (if omitted, falls back to JWT_SECRET)
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret

# Expiry times for JWT tokens
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -----------------------------
# Cloudflare R2 Configurations (Required for creator upload uploads and variants generation)
# -----------------------------
R2_ACCOUNT_ID=your_cloudflare_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-public-bucket-subdomain.r2.dev

# -----------------------------
# Redis Configurations (Required for BullMQ image variant background worker)
# -----------------------------
# Redis TCP Connection URI (Upstash Redis or local redis instance)
REDIS_URL=redis://127.0.0.1:6379

# Upstash Redis REST Caching (Optional fallback caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------
# Stripe Payment Integration (Optional, disables payments if missing)
# -----------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# -----------------------------
# SMTP Email Client Configurations (Optional, debug verification log fallback if missing)
# -----------------------------
EMAIL_USER=your_smtp_email_address@gmail.com
EMAIL_PASS=your_smtp_app_password
EMAIL_FROM="AniCart <your_smtp_email_address@gmail.com>"

# -----------------------------
# Frontend Client Access Configuration
# -----------------------------
CLIENT_URL=http://localhost:3000

# -----------------------------
# Sentry Error Reporting & Logs Monitoring (Optional)
# -----------------------------
SENTRY_DSN=

# BCrypt Salt Strength Configuration
BCRYPT_SALT_ROUNDS=12
